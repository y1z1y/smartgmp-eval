{
    "id": "share-popup",
    "name": "分享图标组件",
    "version": "1.0.0",
    "description": "分享入口图标组件，支持展示位置、垂直偏移和分享触发埋点，迁移自 mf-share-popup",
    "previewUrl": "https://ut-static.udache.com/webx/yingkesong/d9leLbvTYoW63D6dTwsJ8_image.webp",
    "category": "marketing",
    "tags": [
        "分享",
        "图标",
        "浮层",
        "营销"
    ],
    "import": {
        "package": "@smartgmp-components/share-popup",
        "exportName": "default",
        "type": "React.ComponentType<SharePopupProps>"
    },
    "props": {
        "isVisible": {
            "type": "boolean",
            "required": false,
            "description": "是否展示",
            "default": true,
            "category": "基础配置"
        },
        "iconImg": {
            "type": "string",
            "required": false,
            "description": "分享图标图片地址，默认使用原组件 CDN 图",
            "default": "https://img-hxy021.didistatic.com/static/starimg/img/MkaTahZbYJ1678439403242.png",
            "category": "图片配置"
        },
        "defaultSite": {
            "type": "'left' | 'right'",
            "required": false,
            "description": "图标默认靠左或靠右",
            "default": "right",
            "category": "布局配置"
        },
        "verticalOffsetDistance": {
            "type": "number",
            "required": false,
            "description": "图标垂直偏移距离",
            "default": 0,
            "category": "布局配置"
        }
    },
    "defaultImageProps": {
        "iconImg": "https://img-hxy021.didistatic.com/static/starimg/img/MkaTahZbYJ1678439403242.png"
    },
    "aiGenerationGuide": {
        "purpose": "分享入口图标组件，用于活动页右侧或左侧悬浮分享入口，点击后触发分享能力或遮罩兜底",
        "usageScenarios": [
            "活动页悬浮分享入口",
            "营销活动分享按钮",
            "需要引导用户唤起分享面板的页面"
        ],
        "keyFeatures": [
            "默认展示分享图标",
            "支持左/右侧定位",
            "支持垂直偏移",
            "点击后在可分享环境触发原生分享",
            "非分享环境下派发遮罩事件兜底",
            "保留原组件埋点事件"
        ],
        "layoutStructure": {
            "container": "绝对定位图标容器，默认 47×47，top: 3px",
            "image": "img.share-popup__img，撑满容器"
        },
        "styleGuide": {
            "prefix": "mf-assets-share-popup",
            "placement": "absolute + left/right = 0",
            "size": "47px × 47px"
        },
        "bestPractices": [
            "默认图标直接使用内置 CDN 图，少传 props 即可预览",
            "建议放在页面相对定位容器内，确保绝对定位符合预期",
            "分享环境外部兜底事件名为 share:handleShowMask"
        ],
        "codeExample": "import SharePopup from '@smartgmp-components/share-popup';\n\nfunction Page() {\n  return <SharePopup defaultSite=\"right\" verticalOffsetDistance={0} />;\n}"
    },
    "apis": [],
    "tracking": {
        "events": [{
            "name": "xy_px_sharebtn_ck",
            "description": "分享图标点击"
        }]
    },
    "meta": {
        "author": "smartgmp-team",
        "createdAt": "2026-05-27T00:00:00Z"
    }
}